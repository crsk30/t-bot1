# NSE Algo Trading - Environment Variables
# Copy this to .env and fill in your values

# API Gateway
PORT=3000
PYTHON_API_URL=http://localhost:8000

# JWT Secret (for future auth extension)
JWT_SECRET=change-this-to-a-long-random-string

# Broker (set to 'paper' for simulation, 'kite' for Zerodha, etc.)
BROKER=paper
PAPER_CAPITAL=500000

# Zerodha Kite Connect (if using Zerodha)
KITE_API_KEY=
KITE_API_SECRET=

# Upstox (if using Upstox)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Angel One SmartAPI (if using Angel)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=

# ─── Journal Email Scheduler ──────────────────────────────────────────────────
# Sends the AutoTrader Thought Journal to EMAIL_TO every day at 3:28 PM IST.
#
# Gmail users:
#   1. Enable 2-Step Verification on your Google account.
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Create an App Password (select "Mail" + "Other") and paste it below.
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# Outlook / Hotmail users:
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=sai.crsk30@gmail.com
SMTP_PASS=false
EMAIL_FROM=sai.crsk30@gmail.com
EMAIL_TO=saikrishna.ramamoorthy@gmail.com

# Cron schedule for the journal email (default: 3:28 PM IST, weekdays Mon–Fri)
# Format: "minute hour * * day-of-week"  (uses Asia/Kolkata timezone)
# Examples:
#   "28 15 * * 1-5"  → 3:28 PM Mon–Fri  (default)
#   "28 15 * * *"    → 3:28 PM every day
JOURNAL_CRON=28 15 * * 1-5
