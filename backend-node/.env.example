# NSE Algo Trading - Environment Variables
# Copy this to .env and fill in your values

# API Gateway
PORT=3000
PYTHON_API_URL=http://localhost:8000

# JWT Secret (for future auth extension)
JWT_SECRET=change-this-to-a-long-random-string

# Broker (set to 'paper' for simulation, 'kite' for Zerodha, etc.)
BROKER=paper
PAPER_CAPITAL=500000

# Zerodha Kite Connect (if using Zerodha)
KITE_API_KEY=
KITE_API_SECRET=

# Upstox (if using Upstox)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=

# Angel One SmartAPI (if using Angel)
ANGEL_API_KEY=
ANGEL_CLIENT_ID=
ANGEL_MPIN=
ANGEL_TOTP_SECRET=
